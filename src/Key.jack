class Key {
  field String name;
  field int id;
  field boolean broken;

  constructor Key new(int x, String y) {
    let id = x;
    let name = y;
    let broken = false;
    return this;
  }

  method void dispose() {
    do Memory.deAlloc(this);
    return;
  }

  method String getName() {
    return name;
  }

  method int getId() {
    return id;
  }

  method boolean isBroken() {
    return broken;
  }

  method void breakKey() {
    let broken = true;
    return;
  }
}